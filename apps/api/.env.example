# FinGuard API defaults: free-tier, keyless, mock-first.
APP_ENV=local
AUTH_REQUIRED=false
PUBLIC_CUSTOMER_CHAT=false
LLM_PROVIDER=mock
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=60

# Optional persistence. Leave blank for local JSON/in-memory fallback.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
FINGUARD_REPOSITORY=

# Optional providers/connectors. Leave blank to keep disabled.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=
OPENROUTER_API_KEY=
